# ═══════════════════════════════════════════════════════════════
#  CONFIGURACIÓN DEL PROYECTO
#
#  1. Copia este archivo y renómbralo a:  .env
#  2. Rellena tu clave de Groq (obligatoria)
#  3. Cambia los puertos SOLO si ya están ocupados en tu máquina
# ═══════════════════════════════════════════════════════════════

# ── OBLIGATORIO: tu clave API de Groq (gratuita) ────────────────
# Consíguela en: https://console.groq.com/keys
GROQ_API_KEY=gsk_PON_AQUI_TU_CLAVE

# ── Puertos en tu máquina (cámbialos si dan conflicto) ──────────
# Puerto del editor de n8n         → http://localhost:5678
N8N_PORT=5678
# Puerto de la interfaz web        → http://localhost:8080
WEB_PORT=8080

# ── Zona horaria ────────────────────────────────────────────────
TZ=Europe/Madrid
